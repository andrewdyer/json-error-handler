{
  "name": "andrewdyer/json-error-handler",
  "description": "A structured JSON error handler for Slim Framework applications that maps exceptions to typed, consistent error payloads",
  "keywords": [
    "php",
    "slim",
    "slim-framework",
    "error-handler",
    "json",
    "exceptions"
  ],
  "type": "library",
  "license": "MIT",
  "authors": [
    {
      "name": "Andrew Dyer",
      "homepage": "https://andrewdyer.rocks",
      "role": "Developer"
    }
  ],
  "homepage": "https://github.com/andrewdyer/json-error-handler",
  "support": {
    "issues": "https://github.com/andrewdyer/json-error-handler/issues",
    "source": "https://github.com/andrewdyer/json-error-handler"
  },
  "autoload": {
    "psr-4": {
      "AndrewDyer\\JsonErrorHandler\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "AndrewDyer\\JsonErrorHandler\\Tests\\": "tests/"
    }
  },
  "require": {
    "php": "^8.3",
    "andrewdyer/actions": "^1.2",
    "psr/http-factory": "^1.1",
    "psr/http-message": "^1.1 || ^2.0",
    "psr/log": "^1.1 || ^2.0 || ^3.0",
    "slim/slim": "^4.15"
  },
  "require-dev": {
    "friendsofphp/php-cs-fixer": "^3.75",
    "phpunit/phpunit": "^10.5",
    "slim/psr7": "^1.8"
  },
  "scripts": {
    "cs": "php-cs-fixer fix",
    "test": "phpunit"
  },
  "config": {
    "sort-packages": true
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
